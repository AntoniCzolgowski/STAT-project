# ============================================================
# R (standard R.gitignore)
# ============================================================

# History files
.Rhistory
.Rapp.history
# Session Data files
.RData
.RDataTmp
# User-specific files
.Ruserdata
# Example code in package build process
*-Ex.R
# Output files from R CMD build
/*.tar.gz
# Output files from R CMD check
/*.Rcheck/
# RStudio files (per-user)
.Rproj.user/
*.Rproj
# produced vignettes
vignettes/*.html
vignettes/*.pdf
# OAuth2 token
.httr-oauth
# knitr and R markdown default cache directories
*_cache/
/cache/
# Temporary files created by R markdown
*.utf8.md
*.knit.md
# R Environment Variables
.Renviron
# pkgdown site
docs/
# translation temp files
po/*~
# RStudio Connect folder
rsconnect/

# ============================================================
# renv — keep lockfile + activate script, ignore installed packages
# ============================================================
renv/library/
renv/staging/
renv/python/
renv/local/
renv/cellar/
# NOTE: renv.lock and renv/activate.R are NOT ignored (must be committed)

# ============================================================
# Derived data — regenerable from data/raw + scripts
# Teammates re-run scripts to produce these locally
# ============================================================
data/raw/*
!data/raw/.keep
data/interim/
data/processed/

# ============================================================
# OS cruft
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# Editors / IDEs (per-user)
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================
# Claude Code local state
# ============================================================
.claude/
